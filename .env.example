# ============================================
# Admin CMS Configuration
# ============================================
# Copy this file to .env.local and fill in the values

# Auth.js Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Repository to commit content to
GITHUB_OWNER=your-username
GITHUB_REPO=your-repo
GITHUB_BRANCH=main

# Optional: Restrict access to specific GitHub org members
# GITHUB_ALLOWED_ORG=your-org
# GITHUB_ORG_CHECK_TOKEN=ghp_xxx

# ============================================
# Admin Mode
# ============================================
# Set to 'true' to enable dynamic admin routes
# When false, site builds as static export
ADMIN_MODE=true
